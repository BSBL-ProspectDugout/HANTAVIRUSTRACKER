# Google AdSense
# Get your ad client ID from Google AdSense dashboard
# Format: ca-pub-xxxxxxxxxxxxxxxx (without "ca-pub-" prefix, just the numbers)
NEXT_PUBLIC_GOOGLE_AD_CLIENT_ID=0000000000000000

# Google Analytics (for tracking visitors and SEO insights)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# News API (for real-time hantavirus news)
# Sign up at https://newsapi.org/ for free API key
NEXT_PUBLIC_NEWS_API_KEY=your_newsapi_key_here

# CDC API (if needed)
CDC_API_KEY=your_cdc_key_here

# Optional: Database for storing historical data
DATABASE_URL=postgresql://user:password@localhost:5432/hantavirus

# Optional: Analytics (Google Analytics, Plausible, etc.)
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Environment
NEXT_PUBLIC_ENVIRONMENT=development
