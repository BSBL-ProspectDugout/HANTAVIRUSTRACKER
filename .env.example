# ============================================================
# REQUIRED: News Data API
# ============================================================
# NewsAPI - Get free API key at https://newsapi.org/
NEXT_PUBLIC_NEWS_API_KEY=5a7a7d9ae92f4e8f81889377c73dab1d

# ============================================================
# GOOGLE ANALYTICS - Real-time visitor tracking
# ============================================================
# Get from: https://analytics.google.com/
# Format: G-XXXXXXXXXX (Google Analytics 4 Measurement ID)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================================
# GOOGLE ADSENSE - Ad revenue
# ============================================================
# Get from: https://adsense.google.com/
# Go to Account > Account information > Publisher ID
# Format: Just the numbers from ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_AD_CLIENT_ID=XXXXXXXXXXXXXXXX

# ============================================================
# OPTIONAL: Google Search Console
# ============================================================
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code

# ============================================================
# OPTIONAL: Additional Tracking
# ============================================================
# For storing historical outbreak data
# DATABASE_URL=postgresql://user:password@localhost:5432/hantavirus

# Environment stage
NEXT_PUBLIC_ENVIRONMENT=production
